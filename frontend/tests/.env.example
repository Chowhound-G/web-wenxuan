# ============================================================
# 元气购 Web 端 E2E 测试配置（复制为 .env 或直接 export 到环境）
# 所有项均为可选；不设置时使用 tests/config/test.config.ts 的默认值
# ============================================================

# --- 地址 ---
# 前端 Web 基础地址（默认 http://127.0.0.1:5173）
TEST_BASE_URL=http://127.0.0.1:5173
# 后端 API 基础地址（默认 http://localhost:8080/api）
TEST_API_BASE=http://localhost:8080/api

# --- 普通用户账号（主流程登录） ---
TEST_USER_ACCOUNT=user@example.com
TEST_USER_PASSWORD=123456

# --- 注册用新账号（每次跑会尝试注册，建议唯一） ---
TEST_NEW_USER_ACCOUNT=test_register@example.com
TEST_NEW_USER_PASSWORD=123456

# --- 管理员账号（知识库后台） ---
TEST_ADMIN_ACCOUNT=admin
TEST_ADMIN_PASSWORD=123456

# --- 业务数据 ---
# 商品详情测试使用的商品 ID
TEST_PRODUCT_ID=1

# --- 运行参数 ---
# 默认超时(ms)
TEST_DEFAULT_TIMEOUT=30000
# CI 模式（playwright.config 已支持，置 1 启用）
# CI=1
